#
# Allow the fpm user to write on all files (except .git dirs)
#
# Usage: vhost-write-unlock
#

[ -z "${KCLIE_PATH}" ] && KCLIE_PATH=$(dirname ${BASH_SOURCE[0]:-$0})/../

source ${KCLIE_PATH}/lib/vhost.bash

GetVhostDirFromCurrentDir
if [ "x${VHOST_DIR}" = "x" ] ; then
    echo -e "Currently not in a existing vhost."
    exit 1
fi

# ensure files owner
${KCLIE_PATH}/bin/vhost-chown-reinit

# Allow the fpm user to write on the entire docroot
chmod -R ug+w ${VHOST_DIR}/www

# keep .git dirs hidden for fpm user
find ${VHOST_DIR} -name .git -exec chmod -R go-w {} \;