#
# Lock all files in readonly for the fpm user except minimal Wordpress needed directories for writing content.
#
# Usage: vhost-write-lock-wp
#

[ -z "${KCLIE_PATH}" ] && KCLIE_PATH=$(dirname ${BASH_SOURCE[0]:-$0})/../

source ${KCLIE_PATH}/lib/vhost.bash

GetVhostDirFromCurrentDir
if [ "x${VHOST_DIR}" = "x" ] ; then
    echo -e "Currently not in a existing vhost."
    exit 1
fi

# ensure files owner
${KCLIE_PATH}/bin/vhost-chown-reinit

# make read only for fpm user
chmod -R go-w ${VHOST_DIR}/www

# allow write on specific dirs only
for CONTENT_DIR in "cache" "languages" "uploads" "webp-express/config" "wflogs" "wp-rocket-config" ; do
    if [ -e ${VHOST_DIR}/www/wp-content/${CONTENT_DIR} ] ; then
       chmod -R g+w ${VHOST_DIR}/www/wp-content/${CONTENT_DIR}
    fi
done

# disallow php in uploads
if [ ! -e ${VHOST_DIR}/www/wp-content/uploads/.htaccess ] ; then
    echo -e "<Files *.php>\nRequire all denied\n</Files>" > ${VHOST_DIR}/www/wp-content/uploads/.htaccess
fi
chmod go-w ${VHOST_DIR}/www/wp-content/uploads/.htaccess